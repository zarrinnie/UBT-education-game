# Terjemahan Bahasa Indonesia — dialog dan pilihan cerita UBT Trainer.

# game/script.rpy:22
translate indonesian scene_intro_8b4bde3a:

    # "You are a nurse on the maternity ward of a rural clinic."
    "Anda adalah seorang perawat di bangsal bersalin sebuah klinik pedesaan."

# game/script.rpy:23
translate indonesian scene_intro_959243a7:

    # "Your patient, Maria, delivered a healthy baby twenty minutes ago. Suddenly, the doctor calls you urgently."
    "Pasien Anda, Maria, melahirkan bayi yang sehat dua puluh menit yang lalu. Tiba-tiba, dokter memanggil Anda dengan mendesak."

# game/script.rpy:24
translate indonesian scene_intro_eda9b7ca:

    # dr "I need you here, now! Maria is bleeding heavily and it isn't slowing down."
    dr "Saya butuh Anda di sini, sekarang! Maria mengalami perdarahan hebat dan tidak kunjung berkurang."

# game/script.rpy:25
translate indonesian scene_intro_4cdad2f2:

    # "Every decision from here on counts. Your training starts now."
    "Setiap keputusan mulai dari sini sangat menentukan. Pelatihan Anda dimulai sekarang."

# game/script.rpy:38
translate indonesian scene_assessment_5f942b80:

    # dr "Here are her vitals. She delivered vaginally, the placenta is out and complete, and an oxytocin infusion is already running — but the bleeding continues."
    dr "Ini tanda-tanda vitalnya. Ia melahirkan secara pervaginam, plasenta sudah lahir lengkap, dan infus oksitosin sudah berjalan — tetapi perdarahan terus berlanjut."

# game/script.rpy:68
translate indonesian scene_call_for_help_2475e3f8:

    # dr "You've recognised the emergency. What do you do first?"
    dr "Anda telah mengenali kegawatdaruratan ini. Apa yang Anda lakukan pertama kali?"

# game/script.rpy:87
translate indonesian scene_call_for_help_21612492:

    # dr "The team is here. Uterotonics haven't stopped the bleeding — the uterus is atonic. We need a uterine balloon tamponade."
    dr "Tim sudah datang. Uterotonika belum menghentikan perdarahan — uterusnya atonia. Kita memerlukan tamponade balon uterus."

# game/script.rpy:94
translate indonesian scene_equipment_prep_c5daa393:

    # dr "Gather the UBT equipment onto the sterile tray. Quickly, but choose carefully."
    dr "Kumpulkan peralatan UBT ke atas baki steril. Cepat, tetapi pilih dengan cermat."

# game/script.rpy:99
translate indonesian scene_equipment_prep_e3110192:

    # dr "Good. Everything we need is on the tray. Gloves on — let's begin."
    dr "Bagus. Semua yang kita butuhkan sudah ada di baki. Kenakan sarung tangan — mari kita mulai."

# game/script.rpy:106
translate indonesian scene_procedure_c2af486e:

    # dr "I'll guide you through the insertion. Follow each step in order."
    dr "Saya akan memandu Anda melakukan pemasangan. Ikuti setiap langkah secara berurutan."

# game/script.rpy:110
translate indonesian scene_procedure_2442ef37:

    # "Speculum inserted. The cervix is now visible."
    "Spekulum terpasang. Serviks kini terlihat."

# game/script.rpy:114
translate indonesian scene_procedure_5e23f9ae:

    # "You pass the UBT balloon catheter through the cervix into the uterine cavity."
    "Anda memasukkan kateter balon UBT melalui serviks ke dalam rongga uterus."

# game/script.rpy:118
translate indonesian scene_procedure_6101de2a:

    # "The 50mL syringe is connected to the catheter's inflation port."
    "Spuit 50mL tersambung ke port inflasi kateter."

# game/script.rpy:122
translate indonesian scene_procedure_a408fc24:

    # "The balloon is inflated with [inflate_volume]mL of normal saline."
    "Balon diisi dengan [inflate_volume]mL cairan salin normal."

# game/script.rpy:127
translate indonesian scene_procedure_a33013ca:

    # "The catheter is clamped. The balloon is locked in place."
    "Kateter telah diklem. Balon terkunci pada tempatnya."

# game/script.rpy:153
translate indonesian scene_assessment_check_e9af9852:

    # dr "The balloon is in place. What do you check now?"
    dr "Balon sudah terpasang. Apa yang Anda periksa sekarang?"

# game/script.rpy:172
translate indonesian scene_assessment_check_405df30b:

    # dr "Bleeding has stopped — tamponade test positive. Well done. Now she needs close monitoring."
    dr "Perdarahan telah berhenti — tes tamponade positif. Kerja bagus. Sekarang ia memerlukan pemantauan ketat."

# game/script.rpy:182
translate indonesian scene_monitoring_a9e8b89a:

    # "Monitoring plan confirmed. Maria remains stable. The balloon will stay in place for 24–48 hours, then be deflated gradually while watching for re-bleeding."
    "Rencana pemantauan dikonfirmasi. Kondisi Maria tetap stabil. Balon akan dipertahankan selama 24–48 jam, lalu dikempiskan secara bertahap sambil mengawasi perdarahan ulang."

# game/script.rpy:190
translate indonesian scene_quiz_532f7c4c:

    # dr "Maria is safe. Before we finish — a quick knowledge check. Five questions."
    dr "Maria selamat. Sebelum kita selesai — uji pengetahuan singkat. Lima pertanyaan."

translate indonesian strings:

    # game/script.rpy:43
    old "Look at the vitals. Is this postpartum hemorrhage (PPH)?"
    new "Perhatikan tanda-tanda vitalnya. Apakah ini perdarahan pascapersalinan (PPH)?"

    # game/script.rpy:46
    old "Yes — blood loss over 500mL with signs of shock."
    new "Ya — kehilangan darah lebih dari 500mL disertai tanda-tanda syok."

    # game/script.rpy:47
    old "Correct"
    new "Benar"

    # game/script.rpy:47
    old "Blood loss above 500mL after vaginal delivery is PPH. Her fast heart rate, low blood pressure and pale, clammy skin mean she is going into shock. Act now."
    new "Kehilangan darah lebih dari 500mL setelah persalinan pervaginam adalah PPH. Denyut jantung yang cepat, tekanan darah rendah, serta kulit pucat dan lembap dingin menandakan ia mulai mengalami syok. Bertindaklah sekarang."

    # game/script.rpy:50
    old "No — this is normal postpartum bleeding."
    new "Tidak — ini perdarahan pascapersalinan yang normal."

    # game/script.rpy:51
    old "Assessment: mistook PPH for normal bleeding. More than 500mL after vaginal delivery, with signs of shock, is PPH."
    new "Penilaian: mengira PPH sebagai perdarahan normal. Lebih dari 500mL setelah persalinan pervaginam, disertai tanda syok, adalah PPH."

    # game/script.rpy:52
    old "Incorrect"
    new "Salah"

    # game/script.rpy:52
    old "This is not normal. Blood loss above 500mL after vaginal delivery is PPH — and her fast heart rate, low blood pressure and clammy skin are signs of shock."
    new "Ini tidak normal. Kehilangan darah lebih dari 500mL setelah persalinan pervaginam adalah PPH — dan denyut jantung cepat, tekanan darah rendah, serta kulit lembap dinginnya adalah tanda-tanda syok."

    # game/script.rpy:55
    old "Unsure — wait and observe."
    new "Ragu — tunggu dan amati dulu."

    # game/script.rpy:56
    old "Assessment: waited instead of acting. Delay costs lives in PPH — recognise and act immediately."
    new "Penilaian: menunggu alih-alih bertindak. Penundaan merenggut nyawa pada PPH — kenali dan bertindaklah segera."

    # game/script.rpy:57
    old "There is no time to wait. Blood loss above 500mL with signs of shock is PPH. Every minute of delay increases the danger to the mother's life."
    new "Tidak ada waktu untuk menunggu. Kehilangan darah lebih dari 500mL disertai tanda syok adalah PPH. Setiap menit penundaan memperbesar bahaya bagi nyawa sang ibu."

    # game/script.rpy:70
    old "What do you do first?"
    new "Apa yang Anda lakukan pertama kali?"

    # game/script.rpy:73
    old "Shout for help and call the emergency team."
    new "Berteriak minta bantuan dan panggil tim gawat darurat."

    # game/script.rpy:74
    old "PPH is a team emergency. Call for help first — you need extra hands for medication, monitoring, and preparing equipment while you stay with the patient."
    new "PPH adalah kegawatdaruratan tim. Panggil bantuan terlebih dahulu — Anda membutuhkan tenaga tambahan untuk pemberian obat, pemantauan, dan penyiapan peralatan sementara Anda tetap mendampingi pasien."

    # game/script.rpy:77
    old "Insert the balloon immediately, by yourself."
    new "Segera pasang balon, seorang diri."

    # game/script.rpy:78
    old "First response: tried to manage PPH alone. Always call the team first — PPH management needs several people working together."
    new "Respons pertama: mencoba menangani PPH sendirian. Selalu panggil tim terlebih dahulu — penanganan PPH membutuhkan beberapa orang yang bekerja sama."

    # game/script.rpy:79
    old "Never manage PPH alone. Call for help first — one person cannot give drugs, monitor vitals, prepare equipment and perform the procedure at the same time."
    new "Jangan pernah menangani PPH sendirian. Panggil bantuan terlebih dahulu — satu orang tidak mungkin memberikan obat, memantau tanda vital, menyiapkan peralatan, dan melakukan prosedur secara bersamaan."

    # game/script.rpy:82
    old "Quietly recheck her blood pressure."
    new "Diam-diam periksa ulang tekanan darahnya."

    # game/script.rpy:83
    old "First response: rechecked BP instead of calling for help. The diagnosis is already clear — escalate immediately."
    new "Respons pertama: memeriksa ulang tekanan darah alih-alih memanggil bantuan. Diagnosisnya sudah jelas — segera eskalasikan."

    # game/script.rpy:84
    old "The vitals already tell the story. Rechecking wastes precious minutes — call the emergency team immediately, then continue monitoring."
    new "Tanda-tanda vital sudah berbicara. Memeriksa ulang hanya membuang menit-menit berharga — segera panggil tim gawat darurat, lalu lanjutkan pemantauan."

    # game/script.rpy:139
    old "Inflation: under-inflated the balloon (%dmL). 250–500mL is needed for effective tamponade."
    new "Inflasi: balon kurang terisi (%dmL). Dibutuhkan 250–500mL untuk tamponade yang efektif."

    # game/script.rpy:140
    old "Under-inflated"
    new "Kurang terisi"

    # game/script.rpy:140
    old "With less than 250mL, the balloon cannot press firmly against the uterine wall — the bleeding will continue. Draw up more saline and try again."
    new "Dengan kurang dari 250mL, balon tidak dapat menekan kuat dinding uterus — perdarahan akan berlanjut. Tambahkan cairan salin dan coba lagi."

    # game/script.rpy:144
    old "Inflation: over-inflated the balloon (%dmL). More than 500mL risks uterine injury."
    new "Inflasi: balon terlalu penuh (%dmL). Lebih dari 500mL berisiko mencederai uterus."

    # game/script.rpy:145
    old "Over-inflated"
    new "Terlalu penuh"

    # game/script.rpy:145
    old "More than 500mL over-distends the uterus and risks rupture or balloon failure. Release some saline and try again."
    new "Lebih dari 500mL membuat uterus terlalu teregang dan berisiko ruptur atau kegagalan balon. Keluarkan sebagian cairan salin dan coba lagi."

    # game/script.rpy:155
    old "The balloon is in place. What do you check now?"
    new "Balon sudah terpasang. Apa yang Anda periksa sekarang?"

    # game/script.rpy:158
    old "Check whether the bleeding has stopped — the tamponade test."
    new "Periksa apakah perdarahan telah berhenti — tes tamponade."

    # game/script.rpy:159
    old "If bleeding stops or slows markedly after inflation, the tamponade test is positive — the balloon is working. If bleeding continues, she needs escalation."
    new "Jika perdarahan berhenti atau melambat drastis setelah inflasi, tes tamponade positif — balon bekerja. Jika perdarahan berlanjut, ia memerlukan eskalasi."

    # game/script.rpy:162
    old "Deflate the balloon to check underneath."
    new "Kempiskan balon untuk memeriksa bagian di baliknya."

    # game/script.rpy:163
    old "Post-insertion: deflated the balloon immediately. It must stay inflated for 24–48 hours to control the bleeding."
    new "Pasca-pemasangan: langsung mengempiskan balon. Balon harus tetap terisi selama 24–48 jam untuk mengendalikan perdarahan."

    # game/script.rpy:164
    old "Never deflate the balloon right after insertion — it must stay inflated for 24–48 hours. Instead, check whether visible bleeding has stopped: the tamponade test."
    new "Jangan pernah mengempiskan balon segera setelah pemasangan — balon harus tetap terisi selama 24–48 jam. Sebagai gantinya, periksa apakah perdarahan yang tampak telah berhenti: tes tamponade."

    # game/script.rpy:167
    old "Give more oxytocin and wait."
    new "Berikan oksitosin tambahan dan tunggu."

    # game/script.rpy:168
    old "Post-insertion: relied on oxytocin alone instead of doing the tamponade test first."
    new "Pasca-pemasangan: hanya mengandalkan oksitosin alih-alih melakukan tes tamponade terlebih dahulu."

    # game/script.rpy:169
    old "Partially right"
    new "Sebagian benar"

    # game/script.rpy:169
    old "Uterotonics do continue alongside UBT — but first you must confirm the balloon is working. Check whether the bleeding has stopped: the tamponade test."
    new "Uterotonika memang tetap diberikan bersama UBT — tetapi pertama-tama Anda harus memastikan balon bekerja. Periksa apakah perdarahan telah berhenti: tes tamponade."

    # game/script.rpy:199
    old "Quiz Q%d: %s"
    new "Kuis soal %d: %s"
